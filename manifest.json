{
  "manifestVersion": 5,
  "id": "ch.csps.szh-a11y-indesign-plugin",
  "name": "SZH-CSPS A11Y InDesign Plugin",
  "version": "1.0.0",
  "main": "index.html",
  "description": "Build and verify the two reading orders (Tag RO / Construction RO) of accessible PDFs. Developed by SZH/CSPS.",
  "publisher": "SZH/CSPS — Swiss Centre for Special Needs Education",

  "host": [
    {
      "app": "ID",
      "minVersion": "18.5"
    }
  ],

  "entrypoints": [
    {
      "type": "panel",
      "id": "readingOrderPanel",
      "label": {
        "default": "SZH-CSPS A11Y InDesign Plugin"
      },
      "minimumSize": { "width": 260, "height": 400 },
      "preferredDockedSize": { "width": 448, "height": 700 },
      "preferredFloatingSize": { "width": 448, "height": 700 },
      "maximumSize": { "width": 800, "height": 2000 }
    }
  ],

  "requiredPermissions": {
    "allow": "all"
  }
}
